{
  "id": "quiz-ai-extension",
  "name": "Quiz AI Extension",
  "version": "0.1.0",
  "entry": "plugin.js",
  "permissions": [
    "quiz_read_current_question",
    "network_gemini",
    "secrets_read_plugin",
    "ui_show_panel"
  ],
  "settings_schema": {
    "type": "object",
    "properties": {
      "gemini_model": {
        "type": "string",
        "default": "gemini-3.5-flash",
        "description": "Gemini model used for study-help responses."
      }
    }
  },
  "contributes": {
    "quiz_actions": [
      {
        "id": "study_help",
        "title": "AI Study Help",
        "description": "Explain the current question and provide hints without filling quiz answers."
      }
    ]
  }
}
